<main class="phone-screen" data-phone-title="Fuwa Gomen">
  <div
    id="gomen"
    v-scope="FuwaGomen.createScope()"
    v-cloak
    data-balance="&balance"
    data-spent="&spent"
    data-pokes="&pokes"
  >
    <div class="fg-bar">
      <div class="fg-fill" data-ref="fill"></div>
      <span class="fg-bar-text" data-ref="bar-text"></span>
    </div>

    <div class="fg-bubble">
      <b data-ref="bubble-jp"></b>
      <span data-ref="bubble-en"></span>
    </div>

    <div class="fg-kao" data-ref="mouth"></div>
    <div class="fg-name">ママ</div>

    <div class="fg-papa" data-ref="papa">
      <span class="fg-papa-kao">( ；▽； )</span>
      <span>Papa-money all gone…</span>
    </div>

    <div class="fg-shelf">
      <button type="button" class="fg-food" @click="feed('onigiri', $event)">
        <span class="fg-food-icon">🍙</span>
        <span class="fg-food-price">¥50</span>
      </button>
      <button type="button" class="fg-food" @click="feed('ramen', $event)">
        <span class="fg-food-icon">🍜</span>
        <span class="fg-food-price">¥120</span>
      </button>
      <button type="button" class="fg-food" @click="feed('takoyaki', $event)">
        <span class="fg-food-icon">🐙</span>
        <span class="fg-food-price">¥200</span>
      </button>
      <button type="button" class="fg-food" @click="feed('sushi', $event)">
        <span class="fg-food-icon">🍣</span>
        <span class="fg-food-price">¥300</span>
      </button>
    </div>

    <div class="fg-receipt">
      <div class="fg-receipt-head">🧾 レシート Receipt</div>
      <div class="fg-receipt-list" data-ref="receipt"></div>
      <div class="fg-receipt-total">
        <span class="fg-receipt-total-label">合計 Total</span>
        <span class="fg-receipt-dots"></span>
        <span class="fg-receipt-total-val" data-ref="total">-¥0</span>
      </div>
      <div class="fg-seed" data-ref="seed" hidden>
        <i f-for="r in receipt" data-id="&r.item"></i>
      </div>
    </div>

    <div class="fg-actions">
      <button type="button" class="fg-btn" @click="poke()">Poke (≖ᴗ≖✿)</button>
      <button type="button" class="fg-btn" @click="pet()">Pet ( ˶˘ ³˘)</button>
      <button type="button" class="fg-btn" @click="askPapa()">Papa (-人-)</button>
    </div>
  </div>

  <script src="__BROWSER_JS__"></script>
</main>
